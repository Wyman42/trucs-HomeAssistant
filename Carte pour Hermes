# prérequis: intégration Proxmox pour HA et carte Mushroom

# Carte entete - Mushroom Template
type: custom:mushroom-template-card
primary: HERMES
secondary: >-
  RAM: {{ states('sensor.lxc_hermes_106_memory_total') | int }} Go -/- SSD: {{
  states('sensor.lxc_hermes_106_disk_total') | int }} Go
icon: mdi:server
features_position: bottom
entity: binary_sensor.lxc_hermes_106_status
color: var(--primary-color)
grid_options:
  columns: full
# Carte jauge - Bar Card
type: custom:bar-card
decimal: 2
target: true
entities:
  - entity: sensor.lxc_hermes_106_cpu_used
    name: CPU
    severity:
      - color: var(--success-color)
        from: 0
        to: 25
      - color: var(--warning-color)
        from: 26
        to: 80
      - color: var(--error-color)
        from: 81
        to: 100
  - entity: sensor.lxc_hermes_106_memory_used_percentage
    name: RAM
    severity:
      - color: var(--success-color)
        from: 0
        to: 25
      - color: var(--warning-color)
        from: 26
        to: 80
      - color: var(--error-color)
        from: 81
        to: 100
  - entity: sensor.lxc_hermes_106_disk_used_percentage
    name: SSD
    severity:
      - color: var(--success-color)
        from: 0
        to: 25
      - color: var(--warning-color)
        from: 26
        to: 80
      - color: var(--error-color)
        from: 81
        to: 100
positions:
  indicator: "on"
visibility:
  - condition: state
    entity: binary_sensor.lxc_hermes_106_status
    state: "on"
card_mod:
  style: |
    bar-card-backgroundbar {
    background-color: grey;
    }
    bar-card-card {
    border-radius: 30px;
    border: solid, thin;
    border-color: var(--primary-color);
    }
    bar-card-iconbar {
    color: var(--primary-color);
    }
    bar-card-name {
    font-weight: bold;
    text-shadow: 2px 2px #0005;
    }
# Carte boutons - PIle horizontale et Mushroom entity
type: horizontal-stack
cards:
  - type: custom:mushroom-entity-card
    entity: button.lxc_hermes_106_reboot
    name: Reboot
    tap_action:
      action: toggle
    hold_action:
      action: more-info
  - type: custom:mushroom-entity-card
    entity: button.lxc_hermes_106_start
    name: Start
    tap_action:
      action: toggle
    hold_action:
      action: more-info
    icon: mdi:play
    secondary_info: last-changed
  - type: custom:mushroom-entity-card
    name: STOP
    tap_action:
      action: toggle
    hold_action:
      action: more-info
    entity: button.lxc_hermes_106_stop
    icon_color: red

# Carte solde Deepsekk - graphique
type: history-graph
entities:
  - entity: sensor.solde_deepseek
    color: accent
hours_to_show: 24
show_names: true
logarithmic_scale: false
expand_legend: false
